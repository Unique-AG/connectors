{
  "name": "@unique-ag/unique-public-sdk",
  "description": "Standalone NestJS module wrapping the Unique Public REST API",
  "version": "0.0.1",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "check-types": "tsc --noEmit",
    "style": "biome check .",
    "style:fix": "biome check . --write"
  },
  "dependencies": {
    "@proventuslabs/nestjs-zod": "^2.0.0",
    "@proventuslabs/retry-strategies": "^0.1.2",
    "@qfetch/qfetch": "^0.1.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/testing": "^11.1.6",
    "@opentelemetry/api": "^1.9.0",
    "@suites/di.nestjs": "^3.0.1",
    "@suites/doubles.vitest": "^3.0.1",
    "@suites/unit": "^3.0.1",
    "@swc/core": "^1.13.5",
    "@types/node": "^22.13.14",
    "nestjs-otel": "^7.0.1",
    "reflect-metadata": "^0.2.2",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.7",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "nestjs-otel": "^7"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
