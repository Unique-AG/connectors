{
  "name": "@unique-ag/msgraph-effect-client",
  "description": "Fully typed Microsoft Graph API client built on Effect-TS",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "format": "biome format .",
    "format:fix": "biome format . --write",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "^3.14.0",
    "@effect/schema": "^0.75.0",
    "@effect/platform": "^0.76.0",
    "@effect/platform-node": "^0.71.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.7",
    "@swc/core": "^1.13.5",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
