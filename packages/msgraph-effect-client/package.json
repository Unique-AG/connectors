{
  "name": "@unique-ag/msgraph-effect-client",
  "description": "Fully typed Microsoft Graph API client built on Effect-TS",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "biome check .",
    "lint:fix": "biome check . --write",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "effect": "4.0.0-beta.41",
    "@effect/platform-node": "4.0.0-beta.41"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.41",
    "@swc/core": "^1.13.5",
    "@types/node": "^22.13.14",
    "typescript": "^5.9.2",
    "unplugin-swc": "^1.5.7",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
