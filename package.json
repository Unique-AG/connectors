{
  "name": "@unique-ag/connectors",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "watch:dev": "turbo watch dev --experimental-write-cache",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:check": "turbo db:check",
    "codegen": "turbo codegen",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "test:e2e": "turbo test:e2e",
    "test:e2e:watch": "turbo test:e2e:watch",
    "test:coverage": "turbo test:coverage",
    "style": "biome check .",
    "style:fix": "biome check . --write",
    "check-types": "turbo check-types",
    "check-all": "pnpm style && pnpm check-types && pnpm test && syncpack lint",
    "fix-all": "pnpm style:fix && syncpack fix-mismatches",
    "syncpack": "syncpack",
    "quality": "./scripts/lint.sh",
    "ct:install": "ct install --config .github/configs/ct-install.yaml",
    "helm-docs:sharepoint": "services/sharepoint-connector/deploy/helm-charts/helm-docs.sh",
    "helm-docs:confluence": "services/confluence-connector/deploy/helm-charts/helm-docs.sh",
    "clean:force": "rimraf -g \"**/node_modules\" \"**/.turbo\" \"**/dist\" \"**/.turbo\" \"**/coverage\" \"**/@generated\" \"**/*.tsbuildinfo\" && pnpm store prune && pnpm cache delete"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "rimraf": "6.0.1",
    "syncpack": "14.0.0-alpha.19",
    "turbo": "2.9.16",
    "typescript": "5.9.2",
    "unplugin-swc": "1.5.7",
    "vitest": "3.2.6"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "pnpm@10.28.1",
  "pnpm": {
    "overrides": {
      "minimatch@<3.1.4": "3.1.5",
      "path-to-regexp@>=8.0.0 <8.4.2": "8.4.2",
      "lodash@<=4.17.23": "4.18.1",
      "js-yaml@<4.2.0": "4.2.0"
    }
  }
}
