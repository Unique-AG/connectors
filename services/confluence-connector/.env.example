# =================================================================
# APPLICATION CONFIGURATION
# =================================================================

NODE_ENV=development
LOG_LEVEL=debug
PORT=51349

# Controls whether diagnostic data (emails, usernames, IDs) are logged in full or smeared
# Values: conceal (default, partially masks values) | disclose (shows full values)
# LOGS_DIAGNOSTICS_DATA_POLICY=conceal

# =================================================================
# MONITORING CONFIGURATION
# =================================================================

OTEL_METRICS_EXPORTER=prometheus
OTEL_EXPORTER_PROMETHEUS_HOST=0.0.0.0
OTEL_EXPORTER_PROMETHEUS_PORT=51350

# =================================================================
# TENANT CONFIGURATION
# =================================================================

# Glob pattern to match tenant configuration YAML files
TENANT_CONFIG_PATH_PATTERN=/app/tenant-configs/*-tenant-config.yaml
# Local development example:
# TENANT_CONFIG_PATH_PATTERN=src/tenant-configs/lorand-local-tenant-config.yaml

# =================================================================
# SECRETS (referenced from tenant YAML via os.environ/ pattern)
# =================================================================
# Tenant config YAML files reference these using "os.environ/VAR_NAME".
# Each tenant can reference different env vars for its secrets.

# Confluence OAuth 2.0 (2LO) client secret (auth.mode: oauth_2lo) for both cloud and data-center instances
# CONFLUENCE_CLIENT_SECRET=

# Confluence Personal Access Token (auth.mode: pat)
# CONFLUENCE_PAT=

# Zitadel client secret for external Unique API authentication (unique.serviceAuthMode: external)
# ZITADEL_CLIENT_SECRET=

# =================================================================
# PROXY CONFIGURATION (optional)
# =================================================================
# Configure HTTP proxy for environments where internet access is only available through a proxy.

# Proxy authentication mode: none (default), no_auth, username_password, ssl_tls
# PROXY_AUTH_MODE=none

# Proxy connection settings (required for all modes except 'none')
# PROXY_HOST=proxy.example.com
# PROXY_PORT=8080
# PROXY_PROTOCOL=http

# Basic auth credentials (required for 'username_password' mode)
# PROXY_USERNAME=proxy-user
# PROXY_PASSWORD=proxy-pass

# TLS client certificate (required for 'ssl_tls' mode)
# PROXY_SSL_CERT_PATH=/app/proxy-certs/client.crt
# PROXY_SSL_KEY_PATH=/app/proxy-certs/client.key

# CA bundle for verifying proxy server certificate (optional, for self-signed/private CAs)
# PROXY_SSL_CA_BUNDLE_PATH=/app/proxy-certs/ca.crt

# Custom headers for CONNECT request (optional, JSON string)
# PROXY_HEADERS={"X-Proxy-Header":"value"}
