LOG_LEVEL=debug
SELF_URL=http://localhost:9543
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/onenote_mcp
MICROSOFT_CLIENT_ID=<azure-ad-app-client-id>
MICROSOFT_CLIENT_SECRET=<azure-ad-app-client-secret>
AUTH_ACCESS_TOKEN_EXPIRES_IN_SECONDS=60 # 1 minute
AUTH_REFRESH_TOKEN_EXPIRES_IN_SECONDS=2592000 # 30 days
AUTH_HMAC_SECRET=<hmac-secret> # Random 64-char hex secret. Create with e.g. openssl rand -hex 32
ENCRYPTION_KEY=<encryption-key> # Random 64-char hex secret. Create with e.g. openssl rand -hex 32

# ==== Sync Configuration ====
SYNC_INTERVAL_CRON=*/15 * * * * # Every 15 minutes
SYNC_CONCURRENCY=3 # Max concurrent user syncs
SYNC_PAGE_BATCH_SIZE=20 # Pages to process per batch
SYNC_DEBOUNCE_MS=10000 # Debounce interval (ms) for syncs triggered by page create/update

# ==== Unique API Configuration ====
# Choose one of the two authentication modes below:

# --- Option 1: External Mode (for external deployments) ---
UNIQUE_SERVICE_AUTH_MODE=external
UNIQUE_API_BASE_URL=http://localhost:8092/public/
UNIQUE_SERVICE_EXTRA_HEADERS={"authorization":"Bearer <app-key>","x-app-id":"<app-id>","x-user-id":"<user-id>","x-company-id":"<company-id>"}

# --- Option 2: Cluster Local Mode (for in-cluster deployments) ---
# UNIQUE_SERVICE_AUTH_MODE=cluster_local
# UNIQUE_API_BASE_URL=http://chat.namespace.svc:PORT/public/chat/
# UNIQUE_INGESTION_SERVICE_BASE_URL=http://ingestions.namespace.svc:PORT
# UNIQUE_SERVICE_EXTRA_HEADERS={"x-company-id":"<company-id>","x-user-id":"<user-id>"}

# --- Common Unique API settings ---
# UNIQUE_API_VERSION=2023-12-06
# UNIQUE_ROOT_SCOPE_ID=<root-scope-id>
# UNIQUE_USER_FETCH_CONCURRENCY=5

# OTEL_SERVICE_NAME=onenote-mcp
# OTEL_SERVICE_VERSION
# OTEL_TRACES_EXPORTER=oltp
# OTEL_METRICS_EXPORTER=oltp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:9004
