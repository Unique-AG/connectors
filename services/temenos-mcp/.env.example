LOG_LEVEL=debug
PORT=9543
NODE_ENV=development
APP_BUFFER_LOGS=enabled
# Required: shared secret protecting the /mcp endpoint (URL-path prefix).
# In production, generate once with: openssl rand -hex 32
MCP_API_KEY=my-demo-api-key

# ==== Temenos DataHub API Configuration ====
TEMENOS_API_BASE_URL=https://api.temenos.com/api/v1.0.0
TEMENOS_API_KEY=your-temenos-api-key-here

# ==== OpenTelemetry (optional) ====
# OTEL_SERVICE_NAME=temenos-mcp
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=prometheus
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:9004
# OTEL_EXPORTER_PROMETHEUS_HOST=0.0.0.0
# OTEL_EXPORTER_PROMETHEUS_PORT=51347
