LOG_LEVEL=debug
SELF_URL=http://localhost:9542
DEFAULT_MAIL_FILTERS={"ignoredBefore":"2025-06-06", "ignoredContents": [], "ignoredSenders": []} # JSON string of default mail filters applied when syncing emails (e.g. ignoredBefore limits sync to emails on or after the given date)
AMQP_URL=amqp://rabbitmq:rabbitmq@localhost:5672
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/outlook_semantic_mcp
MICROSOFT_CLIENT_ID=<azure-ad-app-client-id>
MICROSOFT_CLIENT_SECRET=<azure-ad-app-client-secret>
MICROSOFT_WEBHOOK_SECRET=<webhook-secret> # Random 128-char hex secret. Create with e.g. openssl rand -hex 64
MICROSOFT_PUBLIC_WEBHOOK_URL=https://your-devtunnel.euw.devtunnels.ms # Publicly reachable URL for Microsoft webhooks. Local: devtunnel. Prod/QA: typically same as SELF_URL
MICROSOFT_SUBSCRIPTION_EXPIRATION_TIME_HOURS_UTC=3 # Hour of day in UTC when scheduled subscription expirations should occur
AUTH_ACCESS_TOKEN_EXPIRES_IN_SECONDS=60 # 1 minute
AUTH_REFRESH_TOKEN_EXPIRES_IN_SECONDS=2592000 # 30 days
AUTH_HMAC_SECRET=<hmac-secret> # Random 64-char hex secret. Create with e.g. openssl rand -hex 32
ENCRYPTION_KEY=<encryption-key> # Random 64-char hex secret. Create with e.g. openssl rand -hex 32
MCP_DEBUG_MODE=disabled # Debug mode for the MCP server
APP_BUFFER_LOGS=disabled # Whether to buffer logs before writing (reduces I/O) (enabled/disabled)
LOGS_DIAGNOSTICS_DATA_POLICY=conceal # Controls what diagnostic data is logged (conceal/expose)

# ==== Unique API Configuration ====
# Choose one of the two authentication modes below:

# --- Option 1: External Mode (for external deployments) ---
# Uncomment these lines and provide values:
UNIQUE_SERVICE_AUTH_MODE=external
UNIQUE_SERVICE_EXTRA_HEADERS={"authorization":"Bearer <app-key>","x-app-id":"<app-id>","x-user-id":"<user-id>","x-company-id":"<company-id>"}
UNIQUE_STORE_INTERNALLY=disabled # Whether to store emails internally in the Unique knowledge base (enabled/disabled)
UNIQUE_ZITADEL_CLIENT_ID=<zitadel-client-id> # Zitadel OAuth client ID (external auth mode)
UNIQUE_ZITADEL_CLIENT_SECRET=<zitadel-client-secret> # Zitadel OAuth client secret (external auth mode)
UNIQUE_ZITADEL_OAUTH_TOKEN_URL=https://your-zitadel-instance.zitadel.cloud/oauth/v2/token # Zitadel OAuth token URL (external auth mode)
UNIQUE_ZITADEL_PROJECT_ID=<zitadel-project-id> # Zitadel project ID for audience validation (external auth mode)

# --- Option 2: Cluster Local Mode (for in-cluster deployments) ---
# Uncomment these lines and provide values:
# UNIQUE_SERVICE_AUTH_MODE=cluster_local
# UNIQUE_INGESTION_SERVICE_BASE_URL=http://ingestions.namespace.svc:PORT
# UNIQUE_SCOPE_MANAGEMENT_SERVICE_BASE_URL=http://scope-management.namespace.svc:PORT
# UNIQUE_SERVICE_EXTRA_HEADERS={"x-company-id":"<company-id>","x-user-id":"<user-id>"}

# OTEL_SERVICE_NAME=outlook-semantic-mcp
# OTEL_SERVICE_VERSION
# OTEL_TRACES_EXPORTER=oltp
# OTEL_METRICS_EXPORTER=otlp
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:9004
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT
# OTEL_EXPORTER_PROMETHEUS_HOST=0.0.0.0
# OTEL_EXPORTER_PROMETHEUS_PORT=8081
# OTEL_METRIC_EXPORT_INTERVAL=30000
# OTEL_BSP_EXPORT_TIMEOUT=30000
# OTEL_BSP_SCHEDULE_DELAY=5000
# OTEL_BSP_MAX_EXPORT_BATCH_SIZE=512
