{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "description": "Configuration for the backend-service dependency",
      "additionalProperties": true
    },
    "ingress": {
      "type": "object",
      "description": "Ingress configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable ingress resource creation",
          "default": false
        },
        "ingressClassName": {
          "type": "string",
          "description": "Ingress class name (e.g., nginx, traefik)"
        },
        "additionalLabels": {
          "type": "object",
          "description": "Additional labels for the ingress resource",
          "additionalProperties": {
            "type": "string"
          }
        },
        "annotations": {
          "type": "object",
          "description": "Annotations for the ingress resource",
          "additionalProperties": {
            "type": "string"
          }
        },
        "hosts": {
          "type": "array",
          "description": "Ingress hosts configuration",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "description": "Hostname for this ingress rule"
              },
              "paths": {
                "type": "array",
                "description": "Paths for this host",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "description": "Path to match"
                    },
                    "pathType": {
                      "type": "string",
                      "enum": ["Exact", "Prefix", "ImplementationSpecific"],
                      "description": "Path type for matching",
                      "default": "ImplementationSpecific"
                    },
                    "serviceName": {
                      "type": "string",
                      "description": "Backend service name (defaults to chart fullname)"
                    },
                    "servicePort": {
                      "type": "string",
                      "description": "Backend service port name (defaults to 'http')"
                    }
                  },
                  "required": ["path"]
                }
              }
            },
            "required": ["host", "paths"]
          }
        },
        "tls": {
          "type": "array",
          "description": "TLS configuration for the ingress",
          "items": {
            "type": "object",
            "properties": {
              "secretName": {
                "type": "string",
                "description": "Name of the TLS secret"
              },
              "hosts": {
                "type": "array",
                "description": "Hosts covered by this TLS configuration",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": ["secretName", "hosts"]
          }
        }
      },
      "additionalProperties": false
    },
    "grafana": {
      "type": "object",
      "description": "Grafana dashboard configuration",
      "properties": {
        "dashboard": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean",
              "description": "Enable Grafana dashboard creation"
            },
            "folder": {
              "type": "string",
              "description": "Grafana folder name for the dashboard"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "alerts": {
      "type": "object",
      "description": "Prometheus alerting rules configuration",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "Enable PrometheusRule resource creation"
        }
      },
      "additionalProperties": false
    },
    "mcpConfig": {
      "type": "object",
      "description": "Configuration for the Kyckr MCP Server, mapped to environment variables",
      "properties": {
        "enabled": {
          "type": "boolean",
          "description": "If disabled, server.extraEnvCM must be set to []"
        },
        "app": {
          "type": "object",
          "description": "Application configuration",
          "properties": {
            "bufferLogs": {
              "type": "string",
              "enum": ["enabled", "disabled"],
              "description": "Whether to buffer logs before writing. Default: enabled"
            }
          },
          "additionalProperties": false
        },
        "kyckr": {
          "type": "object",
          "description": "Kyckr API configuration",
          "properties": {
            "apiBaseUrl": {
              "type": "string",
              "description": "Kyckr REST API base URL. Defaults to https://test-api.kyckr.com/v2"
            },
            "defaultCustomerReference": {
              "type": "string",
              "description": "Default customer reference forwarded to Kyckr for usage reconciliation"
            },
            "defaultContactEmail": {
              "type": "string",
              "description": "Default contact email for document orders"
            }
          },
          "additionalProperties": false
        },
        "logs": {
          "type": "object",
          "description": "Log settings",
          "properties": {
            "diagnosticsDataPolicy": {
              "type": "string",
              "enum": ["conceal", "expose"],
              "description": "Controls whether diagnostic data is concealed or exposed in logs"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
