{
  "description": "Monitors the Kyckr MCP server. Summary counters at the top for a quick health check. Below: per-tool activity, credit consumption, Kyckr API performance, MCP transport, and Node.js runtime.",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total MCP tool calls in the selected time range, across all 7 Kyckr tools. Survives restarts — queries Prometheus history.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 1 },
      "id": 11,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "round(sum(increase(kyckr_tool_call_duration_ms_count{job=~\"$job\"}[$__range]))) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Tool calls (over time range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total tool calls that failed (Kyckr API rejected the request) in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 1 },
      "id": 12,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "round(sum(increase(kyckr_tool_call_duration_ms_count{job=~\"$job\", result=\"error\"}[$__range]))) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Tool errors (over time range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total Kyckr credits consumed in the selected time range. Credits are charged for paid endpoints (lite/enhanced profile, document orders).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 1 },
      "id": 13,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "round(sum(increase(kyckr_credits_consumed_total{job=~\"$job\"}[$__range]))) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Credits consumed (over time range)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Total Kyckr API requests that returned a 4xx or 5xx status in the selected time range.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 1 },
      "id": 14,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "round(sum(increase(kyckr_api_requests_total{job=~\"$job\", status=~\"4..|5..\"}[$__range]))) or vector(0)",
          "refId": "A"
        }
      ],
      "title": "Kyckr API errors (over time range)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 6 },
      "id": 20,
      "title": "Tool activity",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Tool calls per minute, broken down by tool.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 7 },
      "id": 21,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (tool) (rate(kyckr_tool_call_duration_ms_count{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Tool calls per minute (per tool)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Tool errors per minute, broken down by tool. An error means the Kyckr API rejected the request (4xx/5xx); the tool itself still returns cleanly with `success: false`.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 7 },
      "id": 22,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (tool) (rate(kyckr_tool_call_duration_ms_count{job=~\"$job\", result=\"error\"}[1m])) * 60",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Tool errors per minute (per tool)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Credits consumed per tool over the selected time range. Useful for cost attribution.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "lineWidth": 1, "pointSize": 5 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "id": 23,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (tool) (increase(kyckr_credits_consumed_total{job=~\"$job\"}[$__range])) or vector(0)",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Credits consumed per tool (over time range)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Tool call duration percentiles (p50, p95, p99) per tool. Measured end-to-end from inside the query: includes Kyckr API latency and response parsing.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "ms",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 25 },
      "id": 24,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (tool, le) (rate(kyckr_tool_call_duration_ms_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p50 {{tool}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (tool, le) (rate(kyckr_tool_call_duration_ms_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p95 {{tool}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (tool, le) (rate(kyckr_tool_call_duration_ms_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p99 {{tool}}",
          "refId": "C"
        }
      ],
      "title": "Tool call duration per tool (p50, p95, p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 30,
      "title": "Kyckr API",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Kyckr API requests per minute, broken down by path. Path is normalized so registry ids appear as :id.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 35 },
      "id": 31,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (path, method) (rate(kyckr_api_requests_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "{{method}} {{path}}",
          "refId": "A"
        }
      ],
      "title": "Requests per minute (by path)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Kyckr API responses per minute, broken down by HTTP status code.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "stacking": { "mode": "normal" }
          },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 35 },
      "id": 32,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (status) (rate(kyckr_api_requests_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "title": "Responses per minute (by status)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Kyckr API latency percentiles (p50, p95, p99) per path. Useful to spot slow registries.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "ms",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 44 },
      "id": 33,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.50, sum by (path, le) (rate(kyckr_api_request_duration_ms_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p50 {{path}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.95, sum by (path, le) (rate(kyckr_api_request_duration_ms_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "histogram_quantile(0.99, sum by (path, le) (rate(kyckr_api_request_duration_ms_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p99 {{path}}",
          "refId": "C"
        }
      ],
      "title": "Latency per path (p50, p95, p99)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 },
      "id": 40,
      "title": "MCP transport",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Inbound MCP requests per minute, grouped by HTTP status class. Emitted by @unique-ag/mcp-server-module at the transport layer.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "short",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 54 },
      "id": 41,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (status_class) (rate(mcp_requests_total{job=~\"$job\"}[1m])) * 60",
          "legendFormat": "{{status_class}}",
          "refId": "A"
        }
      ],
      "title": "MCP requests per minute (by status class)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 63 },
      "id": 50,
      "title": "Node.js runtime",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Process and V8 heap memory usage. Watch for steady growth — a slow climb usually means a leak.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "bytes",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 64 },
      "id": 51,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_memory_usage{job=~\"$job\"}",
          "legendFormat": "process",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "v8js_memory_heap_used{job=~\"$job\"}",
          "legendFormat": "v8 heap used",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "v8js_memory_heap_limit{job=~\"$job\"}",
          "legendFormat": "v8 heap limit",
          "refId": "C"
        }
      ],
      "title": "Process memory usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Process CPU utilization. Sustained high values point to busy-loop or sync-blocking work.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "percentunit",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 8, "x": 8, "y": 64 },
      "id": 52,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "process_cpu_utilization{job=~\"$job\"}",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "title": "Process CPU utilization",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Event loop delay mean and p99. High values indicate the event loop is being blocked.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 8, "lineWidth": 2, "pointSize": 5 },
          "unit": "s",
          "min": 0
        }
      },
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 64 },
      "id": 53,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_eventloop_delay_mean{job=~\"$job\"}",
          "legendFormat": "mean",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nodejs_eventloop_delay_p99{job=~\"$job\"}",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "title": "Event loop delay",
      "type": "timeseries"
    }
  ],
  "refresh": "1m",
  "schemaVersion": 42,
  "tags": ["kyckr", "mcp"],
  "templating": {
    "list": [
      {
        "current": { "text": "Prometheus", "value": "prometheus" },
        "includeAll": false,
        "label": "Datasource",
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(kyckr_api_requests_total, job)",
        "includeAll": false,
        "label": "Job",
        "name": "job",
        "query": {
          "query": "label_values(kyckr_api_requests_total, job)",
          "refId": "PrometheusVariableQueryEditor-VariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "",
  "title": "Kyckr MCP",
  "uid": "kyckr-mcp",
  "version": 1
}
