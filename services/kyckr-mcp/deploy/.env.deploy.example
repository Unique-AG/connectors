# Copy to .env.deploy and fill in. The .env.deploy file is gitignored.
# Generate MCP_API_KEY with: openssl rand -hex 32

KYCKR_API_KEY=
MCP_API_KEY=

# Optional. Defaults to https://test-api.kyckr.com/v2 (Kyckr test environment).
# Point at https://api.kyckr.com/v2 for production data.
KYCKR_API_BASE_URL=https://test-api.kyckr.com/v2

# Optional. Forwarded to Kyckr for usage reconciliation.
# KYCKR_DEFAULT_CUSTOMER_REFERENCE=
# KYCKR_DEFAULT_CONTACT_EMAIL=

# Optional. fatal | error | warn | info | debug | trace | silent
# LOG_LEVEL=info
