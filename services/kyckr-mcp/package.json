{
  "name": "@unique-ag/kyckr-mcp",
  "description": "",
  "version": "0.1.0",
  "author": "",
  "private": true,
  "license": "Unique License v1",
  "files": [
    "dist",
    "deploy"
  ],
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "mac:kill-dangling": "lsof -i tcp:9229 | grep node | awk '{print $2}' | xargs -r kill -9 && ps | grep \"[c]onnectors\" | awk '{print $1}' | xargs -r kill -9",
    "debug": "nest start --debug",
    "codegen": "echo \"No codegen for this server\"",
    "style": "biome check .",
    "style:fix": "biome check . --write",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:watch": "vitest watch --config vitest.e2e.config.ts",
    "test:coverage": "vitest run --config vitest.coverage.config.ts && istanbul-badges-readme --style='square-flat'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@nestjs/common": "11.1.18",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.18",
    "@nestjs/platform-express": "11.1.18",
    "@opentelemetry/api": "1.9.0",
    "@proventuslabs/nestjs-zod": "2.0.0",
    "@unique-ag/instrumentation": "workspace:*",
    "@unique-ag/logger": "workspace:*",
    "@unique-ag/mcp-server-module": "workspace:*",
    "@unique-ag/probe": "workspace:*",
    "@unique-ag/utils": "workspace:*",
    "express": "5.1.0",
    "nestjs-otel": "8.0.2",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "5.0.1",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "typeid-js": "1.2.0",
    "undici": "7.24.4",
    "zod": "4.1.5"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.18",
    "@nestjs/schematics": "11.0.10",
    "@nestjs/testing": "11.1.18",
    "@suites/di.nestjs": "3.0.1",
    "@suites/doubles.vitest": "3.0.1",
    "@suites/unit": "3.0.1",
    "@swc/cli": "0.8.1",
    "@swc/core": "1.13.5",
    "@types/express": "5.0.3",
    "@types/node": "22.16.5",
    "@types/supertest": "6.0.3",
    "@vitest/coverage-istanbul": "3.2.4",
    "globals": "16.3.0",
    "istanbul-badges-readme": "1.9.0",
    "source-map-support": "0.5.21",
    "supertest": "7.1.4",
    "type-fest": "5.2.0",
    "typescript": "5.9.2",
    "unplugin-swc": "1.5.7",
    "vitest": "3.2.4"
  }
}
