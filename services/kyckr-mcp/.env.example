LOG_LEVEL=debug
PORT=9542
NODE_ENV=development
APP_BUFFER_LOGS=enabled
# Required: shared secret protecting the /mcp endpoint
MCP_API_KEY=my-demo-api-key

# ==== Kyckr API Configuration ====
KYCKR_API_BASE_URL=https://test-api.kyckr.com/v2
KYCKR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: default customer reference for Kyckr usage reconciliation
KYCKR_DEFAULT_CUSTOMER_REFERENCE=unique-demo-case-001
# Optional: default contact email for document orders
KYCKR_DEFAULT_CONTACT_EMAIL=demo@unique.ai

# ==== OpenTelemetry (optional) ====
# OTEL_SERVICE_NAME=kyckr-mcp
# OTEL_TRACES_EXPORTER=otlp
# OTEL_METRICS_EXPORTER=prometheus
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:9004
# OTEL_EXPORTER_PROMETHEUS_HOST=0.0.0.0
# OTEL_EXPORTER_PROMETHEUS_PORT=51346
